extends ../layout.pug

block content
  h2 Orders
  nav.actions
    a(href="/") Back to dashboard

  if orders.length === 0
    p.empty-state No orders yet. The penguins haven't ordered anything from their igloos.
  else
    table.manifest-table
      thead
        tr
          th Customer
          th Igloo Address
          th Items
          th Total
          th Date
      tbody
        each order in orders
          tr
            td= order.customerName
            td= order.iglooAddress
            td
              ul
                each item in order.items
                  li.num= `${item.name} x${item.quantity} ($${item.price} each)`
            td.price $#{order.total}
            td.num= new Date(order.createdAt).toLocaleString()