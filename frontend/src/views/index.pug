extends layout.pug

block content
  h2 Fresh from the iceberg
  p Browse what's in stock today.

  if products.length === 0
    p.empty-state No products available right now. Check back soon!
  else
    .product-grid
      each product in products
        .product-card
          a(href=`/products/${product._id}`)
            img(src=product.imageUrl alt=product.name)
            h3= product.name
            span.ice-chip= product.category
            span.price $#{product.price}